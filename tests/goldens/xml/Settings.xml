				<top>420</top>
				<height>50</height>
				<label>$LOCALIZE[5]</label>
				<align>center</align>
				<font>font37</font>
				<textcolor>grey</textcolor>
			</control>
			<control type="panel" id="9001">
				<left>0</left>
				<width>100%</width>
				<top>490</top>
				<bottom>0</bottom>
				<onup>9000</onup>
